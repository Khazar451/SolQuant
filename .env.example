# SolQuant Inference Server — Environment Configuration
# All variables are prefixed with SQ_
# Copy to .env and modify as needed.

# ── Model ──────────────────────────────────────────────────────────────────
SQ_MODEL_REPO_ID=Qwen/Qwen2.5-0.5B-Instruct-GGUF
SQ_MODEL_FILENAME=qwen2.5-0.5b-instruct-q4_k_m.gguf
SQ_MODEL_DIR=./models

# ── GPU Offload (MX550 tuning) ─────────────────────────────────────────────
# Qwen2.5-0.5B has 24 layers. Offload all for best speed.
# If OOM, reduce this number (e.g., 18 for partial offload).
SQ_N_GPU_LAYERS=24
SQ_N_CTX=2048
SQ_N_BATCH=512
SQ_N_THREADS=4

# ── VRAM Safety ────────────────────────────────────────────────────────────
SQ_VRAM_TOTAL_MB=2048
SQ_VRAM_BUDGET_MB=1600
SQ_VRAM_WARN_THRESHOLD=0.85

# ── Generation Defaults ───────────────────────────────────────────────────
SQ_MAX_TOKENS=512
SQ_TEMPERATURE=0.7
SQ_TOP_P=0.9
SQ_TOP_K=40
SQ_REPEAT_PENALTY=1.1

# ── Server ─────────────────────────────────────────────────────────────────
SQ_HOST=0.0.0.0
SQ_PORT=8000
SQ_LOG_LEVEL=info

# ── RAG Pipeline ───────────────────────────────────────────────────────────
# MongoDB (use mongodb-atlas-local Docker for local vector search)
# docker run -p 27017:27017 mongodb/mongodb-atlas-local:8.0
RAG_MONGO_URI=mongodb://localhost:27017
RAG_MONGO_DB_NAME=solquant_rag
RAG_MONGO_COLLECTION_NAME=system_logs

# Vector search index
RAG_VECTOR_INDEX_NAME=vector_search_index
RAG_EMBEDDING_FIELD=embedding
RAG_EMBEDDING_DIMENSIONS=384
RAG_SIMILARITY_METRIC=cosine

# Embedding model
RAG_EMBEDDING_MODEL_NAME=all-MiniLM-L6-v2
RAG_EMBEDDING_DEVICE=cpu
RAG_EMBEDDING_BATCH_SIZE=64

# Text chunking
RAG_CHUNK_SIZE=512
RAG_CHUNK_OVERLAP=64

# Retrieval
RAG_RETRIEVAL_TOP_K=3
RAG_RETRIEVAL_SCORE_THRESHOLD=0.0
